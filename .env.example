# =====================================================================
# luban local dev stack — copy to .env before `docker compose up`.
# All values below are DEV-ONLY placeholders. Do NOT reuse in production.
# =====================================================================

# ---- MySQL -------------------------------------------------------------
MYSQL_ROOT_PASSWORD=luban_root_dev
MYSQL_DATABASE=luban
MYSQL_USER=luban
MYSQL_PASSWORD=luban_dev_pass

# ---- Shared secrets (backend + bff MUST share the same values) ---------
# LEAD_ENC_KEY: 32-byte AES-256 key, base64-encoded. Regenerate with:
#   openssl rand -base64 32
LEAD_ENC_KEY=UqmejJTJSLBO3J4HkL1bbkxfgDqhl6aYYUOlF/ZjaeI=

# AUTH_JWT_SECRET: random hex; used by both backend and bff. Regenerate with:
#   openssl rand -hex 32
AUTH_JWT_SECRET=8970a0801fe51cef1702f2dafc320e2c12e9dc4639af0d49704233b3ac9744b9
