# Luban 跨项目 E2E — 环境变量样例
# 复制为 .env 并填入真实值；.env 不入 git

# 后端预置的专用 e2e 账号（MUST：不共用 dev 账号）
LUBAN_E2E_ACCOUNT=
LUBAN_E2E_PASSWORD=

# 各服务地址（docker-compose.e2e.yml 默认映射如下）
LUBAN_E2E_ENGINE_URL=http://127.0.0.1:5173
LUBAN_E2E_WEBSITE_URL=http://127.0.0.1:3000
LUBAN_E2E_JAVA_API=http://127.0.0.1:8080
LUBAN_E2E_GO_API=http://127.0.0.1:8081

# CI 无系统 Chrome 时回退 Playwright 自带 Chromium（仅 CI）
# LUBAN_E2E_USE_PLAYWRIGHT_CHROMIUM=1
