{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "<your-github-token>"
      }
    },
    "figma-mcp-go": {
      "command": "npx",
      "args": ["-y", "@vkhanhqui/figma-mcp-go@latest"],
      "env": {
        "FIGMA_PERSONAL_ACCESS_TOKEN": "<your-figma-token>"
      }
    },
    "figma-official": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp",
      "headers": {
        "X-Figma-Token": "<your-figma-token>"
      }
    },
    "sprint": {
      "command": "node",
      "args": ["packages/sprint-mcp/dist/index.js"],
      "env": {
        "SPRINT_MCP_ROOT": ".",
        "SPRINT_MCP_PORT": "7777"
      }
    }
  }
}
