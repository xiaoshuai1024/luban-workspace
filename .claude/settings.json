{
  "permissions": {
    "allow": [
      "Bash(make *)",
      "Bash(scripts/git/*.sh *)",
      "Bash(scripts/github/*.sh *)",
      "Bash(scripts/coverage/*.sh *)",
      "Bash(scripts/contract-check.sh *)",
      "Bash(scripts/verify-production.sh *)",
      "Bash(git submodule *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git add *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh repo *)",
      "Bash(pnpm test*)",
      "Bash(pnpm run *)",
      "Bash(mvn *)",
      "Bash(go test*)",
      "Bash(go build*)",
      "Bash(node scripts/*.mjs *)",
      "Bash(node scripts/session/*.mjs)",
      "Bash(node packages/sprint-mcp/*)",
      "Bash(node packages/sprint-mcp/dist/*)",
      "Bash(make sprint-*)",
      "Bash(curl localhost:77*)"
    ],
    "deny": [
      "Bash(git push * master*)",
      "Bash(git push * main*)",
      "Bash(rm -rf packages/*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/session/in-progress-summary.mjs"
          },
          {
            "type": "command",
            "command": "node scripts/session/sprint-summary.mjs"
          }
        ]
      }
    ]
  }
}
